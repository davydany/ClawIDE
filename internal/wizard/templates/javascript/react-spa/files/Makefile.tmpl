.PHONY: dev build test lint format clean

# Development
dev:
	npm run dev

start:
	docker compose up -d

stop:
	docker compose down

up: start
shutdown: stop

status:
	docker compose ps -a

ps: status

logs:
ifdef SERVICE
	docker compose logs -f $(SERVICE)
else
	docker compose logs -f
endif

# Build
build:
	npm run build

preview:
	npm run preview

# Testing
test:
	npm test

tests: test

test-watch:
	npm run test:watch

test-coverage:
	npm run test:coverage

# Code Quality
lint:
	npm run lint

lint-fix:
	npm run lint:fix

format:
	npm run format

format-check:
	npm run format:check

# Shell access
bash:
	docker compose exec app sh

# Clean
clean:
	rm -rf dist coverage node_modules
