services:
  db:
    image: postgres:17
    environment:
      POSTGRES_DB: {{.ProjectName}}
      POSTGRES_USER: {{.ProjectName}}
      POSTGRES_PASSWORD: localdev
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{.ProjectName}}"]
      interval: 5s
      timeout: 5s
      retries: 5

  app:
    build: .
    ports:
      - "5000:8080"
    environment:
      - ASPNETCORE_ENVIRONMENT=Development
      - ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database={{.ProjectName}};Username={{.ProjectName}};Password=localdev
    depends_on:
      db:
        condition: service_healthy

volumes:
  pgdata:
