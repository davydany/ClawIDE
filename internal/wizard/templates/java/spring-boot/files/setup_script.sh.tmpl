#!/usr/bin/env bash
set -euo pipefail

echo "Setting up {{.ProjectName}}..."

# Copy environment file if it doesn't exist
if [ ! -f .env ]; then
    cp .env.example .env
    echo "Created .env from .env.example"
fi

# Check for Java
if command -v java &> /dev/null; then
    echo "Java version: $(java -version 2>&1 | head -n 1)"
else
    echo "WARNING: Java not found. Install Java 21+ to run locally."
fi

# Check for Maven
if command -v mvn &> /dev/null; then
    echo "Maven version: $(mvn -version 2>&1 | head -n 1)"
else
    echo "WARNING: Maven not found. Install Maven 3.9+ to build locally."
fi

# Check for Docker
if command -v docker &> /dev/null; then
    echo "Docker found. Starting services..."
    docker compose up -d
    echo "Waiting for database to be ready..."
    sleep 5
    echo "Services started."
else
    echo "WARNING: Docker not found. Install Docker to use docker-compose."
fi

echo ""
echo "Setup complete! Run 'make start' to start the development environment."
