#!/usr/bin/env bash
set -euo pipefail

echo "Setting up {{.ProjectName}}..."

# Copy environment file if it doesn't exist
if [ ! -f .env ]; then
    cp .env.example .env
    echo "Created .env from .env.example"
fi

# Check for Ruby
if command -v ruby &> /dev/null; then
    echo "Ruby version: $(ruby --version)"
else
    echo "WARNING: Ruby not found. Install Ruby 3.3+ to run locally."
fi

# Check for Bundler
if command -v bundle &> /dev/null; then
    echo "Bundler version: $(bundle --version)"
else
    echo "WARNING: Bundler not found. Install Bundler to manage dependencies."
fi

# Check for Docker
if command -v docker &> /dev/null; then
    echo "Docker found. Starting services..."
    docker compose up -d
    echo "Waiting for database to be ready..."
    sleep 5
    echo "Setting up database..."
    docker compose exec web bundle exec rails db:setup
    echo "Services started."
else
    echo "WARNING: Docker not found. Install Docker to use docker-compose."
fi

echo ""
echo "Setup complete! Run 'make start' to start the development environment."
